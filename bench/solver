#!/usr/bin/env python3
import importlib
import json
import os
import sys
from pathlib import Path


HELP_TEXT = """\
AProVE - Automated Program Verification Environment (Docker Container)
http://aprove.informatik.rwth-aachen.de

Usage:
  solver [--timeout N] [--timeout=N] --category NAME [--cert] BENCHMARK
  solver --category NAME --meta

Options:
  --help            Print this help and exit
  --version         Print version and exit
  --name            Print solver name and exit
  --license         Print the AProVE license
  --timeout <N>     Timeout in seconds   (also accepts --timeout=N)
  --category <C>    Category (exact TPDB directory name)
  --cert            Emit CPF2 + convert to CPF3 (CETA-compatible)
  --meta            Print handler metadata as JSON and exit
"""

_DEFAULT_LABELS = ["YES", "NO", "MAYBE", "KILLED", "ERROR"]


def _load_handler(category: str, handlers_dir: Path):
    bench_root = str(handlers_dir.parent)
    if bench_root not in sys.path:
        sys.path.insert(0, bench_root)

    handler_py = handlers_dir / f"{category}.py"
    default_py = handlers_dir / "__default__.py"

    if not category or not handler_py.exists():
        if default_py.exists():
            module_name = "__default__"
        else:
            return None, None
    else:
        module_name = category

    try:
        mod = importlib.import_module(f"handlers.{module_name}")
        return mod, module_name
    except ImportError as e:
        print(f"Error: failed to import handler '{module_name}': {e}", file=sys.stderr)
        return None, None


def _find_handlers_dir() -> Path | None:
    script_dir = Path(__file__).resolve().parent
    candidates = []
    solver_root = os.environ.get("SOLVER_ROOT")
    if solver_root:
        candidates.append(Path(solver_root) / "handlers")
    candidates.extend([
        script_dir.parent / "handlers",
        Path("/opt/solver/handlers"),
        script_dir / "handlers",
    ])
    return next((p for p in candidates if p.is_dir()), None)


def main(argv: list[str]) -> int:
    if argv:
        first = argv[0]
        if first == "--name":
            print("AProVE25")
            return 0
        if first in ("-version", "--version"):
            print("AProVE 2025 Termcomp Version")
            return 0
        if first in ("-help", "--help"):
            sys.stdout.write(HELP_TEXT)
            return 0
        if first in ("-license", "--license"):
            with open("/licenses/aprove", "r", encoding="utf-8") as fh:
                sys.stdout.write(fh.read())
            return 0

    timeout = "60"
    category = ""
    benchmark = ""
    cert = False
    meta = False

    args = list(argv)
    while args:
        arg = args.pop(0)
        match arg:
            case opt if opt.startswith("--timeout="):
                timeout = opt.split("=", 1)[1]
            case "--timeout":
                if not args:
                    print("Error: --timeout requires a value", file=sys.stderr)
                    return 2
                timeout = args.pop(0)
            case opt if opt.startswith("--category="):
                category = opt.split("=", 1)[1]
            case "--category":
                if not args:
                    print("Error: --category requires a value", file=sys.stderr)
                    return 2
                category = args.pop(0)
            case "--cert":
                cert = True
            case "--meta":
                meta = True
            case opt if opt.startswith("--"):
                print(f"Error: unknown option: {opt}", file=sys.stderr)
                return 2
            case bench:
                if benchmark:
                    print(f"Error: multiple benchmarks: '{benchmark}' and '{bench}'", file=sys.stderr)
                    return 2
                benchmark = bench

    handlers_dir = _find_handlers_dir()
    if handlers_dir is None:
        print("Error: handlers dir not found.", file=sys.stderr)
        return 3

    if meta:
        if not category:
            print("Error: --meta requires --category", file=sys.stderr)
            return 2
        mod, _ = _load_handler(category, handlers_dir)
        labels = getattr(mod, "RESULT_LABELS", _DEFAULT_LABELS) if mod else _DEFAULT_LABELS
        print(json.dumps({"result_labels": labels}))
        return 0

    if not benchmark:
        print("Usage: solver --timeout N --category NAME [--cert] BENCHMARK", file=sys.stderr)
        return 2

    if os.environ.get("DEBUG_SOLVER") == "1":
        print(f"DEBUG: HANDLERS={handlers_dir} category={category}", file=sys.stderr)

    mod, module_name = _load_handler(category, handlers_dir)
    if mod is None:
        print(f"Error: no handler for category '{category}' in '{handlers_dir}'", file=sys.stderr)
        return 4

    try:
        output = mod.run(int(timeout), Path(benchmark), cert)
    except Exception as e:  # noqa: BLE001
        print(f"Error: handler '{module_name}' raised: {e}", file=sys.stderr)
        return 1

    sys.stdout.write(output)
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
